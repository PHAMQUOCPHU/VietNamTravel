# URL site khách (Vite frontend user). Admin dùng cho nút "Xem bài viết" (/blog/:id).
# Local: trùng cổng mặc định trong admin/src/config/publicSiteUrl.js nếu không set (5174).
VITE_PUBLIC_SITE_URL=http://localhost:5174

# Tên cũ — vẫn được đọc nếu chưa có VITE_PUBLIC_SITE_URL
# VITE_FRONTEND_URL=http://localhost:5174
