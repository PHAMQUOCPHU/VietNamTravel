VITE_DEV_SERVER_PORT=5174
# Local: URL backend (vd. http://localhost:5001). Không có trailing slash.
VITE_BACKEND_URL=http://localhost:5001

# Vercel (Production): Project → Settings → Environment Variables
# - Thêm VITE_BACKEND_URL = URL HTTPS thật của API (Render/Railway/VPS…), ví dụ https://your-api.onrender.com
# - Deploy lại sau khi lưu biến (Vite chỉ embed env lúc build).
# - Root Directory của project này nên là thư mục `frontend` nếu repo là monorepo.
